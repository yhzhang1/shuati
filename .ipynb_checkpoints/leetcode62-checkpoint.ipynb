   "source": [
    "class Solution:\n",
    "    def uniquePaths(self, m: int, n: int) -> int:\n",
    "        d = [[1] * m for _ in range(n)]\n",
    "        \n",
    "        for i in range(1, n):\n",
    "            for j in range(1, m):\n",
    "                d[i][j] = d[i-1][j] + d[i][j-1]\n",
    "                \n",
    "        return d[-1][-1]"
   ]
  }
 ],
